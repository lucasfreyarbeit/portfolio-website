---
import "../styles/global.css";
import BackButton from "../components/navigation/BackButton.astro";

interface Props {
    title?: string;
}

const { title = "Portfolio Lucas Frey" } = Astro.props;
---

<!doctype html>
<html lang="de">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
</head>

<body>

    <main class="info-page-container">
        

        <div class="info-content">
            <BackButton href="/" />

            <div class="info-slot-wrapper">
                <slot />
            </div>
        </div>

    </main>

</body>
</html>

<style>
.info-page-container {
    display: flex;
    max-width: 960px;
    margin: 0 auto;
}

.info-content {
    flex-grow: 1;
    padding: 2.5rem 2rem;
}

.info-slot-wrapper {
    margin-top: 2rem;
}

.info-slot-wrapper :global(h1),
.info-slot-wrapper :global(h2),
.info-slot-wrapper :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
}

.info-slot-wrapper :global(p) {
    margin-bottom: 1rem;
    line-height: 1.6;
}

@media (max-width: 768px) {
    .info-content {
        padding: 2.5rem 1rem;
    }
}
</style>