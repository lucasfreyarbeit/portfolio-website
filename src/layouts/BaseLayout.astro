---
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
    title?: string;
}

const { title = "Portfolio - Lucas Frey" } = Astro.props;
---

<!doctype html>
<html lang="de">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
</head>

<body>

    <Header />

    <main>
        <slot />
    </main>

    <Footer />

</body>
</html>