---
import "../styles/global.css";

import Header from "../components/navigation/Header.astro";
import Footer from "../components/navigation/Footer.astro";

interface Props {
    title?: string;
}

const { title = "Portfolio Lucas Frey" } = Astro.props;
---

<!doctype html>
<!-- data-theme und data-font steuern barrierefreie Modi -->
<html lang="de" data-theme="light" data-font="default">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
</head>
<body>

    <div class="site-wrapper">
        <Header />

        <main class="main-content">
            <slot />
        </main>

        <Footer />
    </div>

</body>
</html>