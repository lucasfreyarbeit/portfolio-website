---
interface Props {
    href: string;
    variant?: "default" | "red" | "blue";
    download?: boolean | string;
}

const {
    href,
    variant = "default",
    download,
} = Astro.props;
---

<a href={href} download={download} class={`button button--${variant}`}>
    <slot />
</a>

<style>
.button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.22em 0.75em;
    
    font-family: var(--font-heading);
    font-weight: 500;
    font-size: 0.95em;
    text-transform: uppercase;
    text-decoration: none;
    
    background-color: var(--bg-color);
    color: var(--title-color);
    border: 0.13em solid var(--outline-color);
    filter: drop-shadow(0.2em 0.2em 0 var(--shadow-color));
    
    transition: transform 0.08s ease, filter 0.08s ease, background-color 0.15s ease, color 0.15s ease;
}

.button:hover {
    transform: translate(-0.1em, -0.1em);
    filter: drop-shadow(0.3em 0.3em 0 var(--shadow-color));
    cursor: pointer;
}

.button:active {
    transform: translate(0.1em, 0.1em);
    filter: none !important;
}

.button:focus-visible {
    outline: 0.13em solid var(--outline-color);
    outline-offset: 0.25em;
}

.button--default:hover {
    background-color: var(--text-color);
    color: var(--bg-color);
}

.button--red:hover {
    background-color: var(--accent-1);
    color: #ffffff;
}

.button--blue:hover {
    background-color: var(--accent-2);
    color: #ffffff;
}
</style>