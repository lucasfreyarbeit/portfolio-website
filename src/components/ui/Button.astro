---
interface Props {
    href: string;
    variant?: "default" | "red" | "orange" | "blue";
    theme?: "light" | "dark";
}

const {
    href,
    variant = "default",
    theme = "light",
}: Props = Astro.props;
---

<a
    href={href}
    class={`button button--${variant} button--theme-${theme}`}
>
    <slot />
</a>

<style>
.button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.22em 0.75em;
    font-family: "Roboto Mono", monospace;
    font-size: 0.95em;
    text-decoration: none;
    border: 0.13em solid;
    filter: drop-shadow(0.2em 0.2em 0 var(--shadow-color));
    transition:
        background-color 0.15s ease,
        color 0.15s ease,
        border-color 0.15s ease,
        transform 0.08s ease,
        filter 0.08s ease;
}

.button:hover {
    transform: translate(-0.1em, -0.1em);
    filter: drop-shadow(0.3em 0.3em 0 var(--shadow-color));
    cursor: pointer;
}

.button:active {
    transform: translate(0.1em, 0.1em);
    filter: none !important;
}

.button--theme-light {
    --shadow-color: #282828;
    background: #ffffff;
    color: #282828;
    border-color: #282828;
}

.button--theme-light:focus-visible {
    outline: 0.13em solid #282828;
    outline-offset: 0.25em;
}

.button--theme-dark {
    --shadow-color: #000000;
    background: #ffffff;
    color: #282828;
    border-color: #ffffff;
}

.button--theme-dark:focus-visible {
    outline: 0.13em solid #ffffff;
    outline-offset: 0.25em;
}

.button--default:hover {
    background: #515151;
    color: #ffffff;
}

.button--red:hover {
    background: #db5d5d;
    color: #ffffff;
}

.button--orange:hover {
    background: #ff9a55;
    color: #ffffff;
}

.button--blue:hover {
    background: #5d8bff;
    color: #ffffff;
}
</style>