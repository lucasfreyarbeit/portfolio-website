---
interface Props {
    class?: string;
    variant?: "default" | "footer";
}

const { class: className = "", variant = "default" } = Astro.props;
---

<div class={`divider divider--${variant} ${className}`} />

<style>
.divider {
    display: block;
    width: calc(100% - 2rem);
    max-width: 95%;
    height: 2px;
}

.divider--default {
    background-color: var(--divider-color);
    margin: 3rem auto;
}

.divider--footer {
    background-color: var(--divider-footer-color);
    margin-top: 1rem auto;
    margin-bottom: 0rem auto;
}
</style>