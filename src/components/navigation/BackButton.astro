---
import BackIcon from '../../../public/icons/ui/BackIcon.svg';

interface Props {
    href: string;
}

const { href } = Astro.props;
---

<a href={href} class="button">
    <BackIcon class="button-icon" aria-hidden="true" />
    <span>ZURÜCK</span>
</a>

<style>
.button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    padding: .3rem .5rem;
    gap: 0.2rem; 

    text-decoration: none;
    color: var(--title-color);

    /* Zieht sich das JetBrains Mono aus den globalen Variablen */
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: .8rem;

    /* Theme-Variablen statt harter Farben */
    background: var(--bg-color);
    border: 2px solid var(--outline-color);
    filter: drop-shadow(3px 3px 0 var(--shadow-color));

    transition:
        transform .08s,
        filter .08s,
        background-color .15s,
        color .15s;
}

.button-icon {
    width: 1.2rem;
    height: 1.2rem;
    fill: currentColor;
    stroke: currentColor;
}

.button:hover {
    transform: translate(-1.5px, -1.5px);
    filter: drop-shadow(4.5px 4.5px 0 var(--shadow-color));
    
    /* Invertiert die Farben beim Hover, passt sich ans Theme an */
    background: var(--text-color);
    color: var(--bg-color); 
}

.button:active {
    transform: translate(1.5px, 1.5px);
    filter: none;
}
</style>