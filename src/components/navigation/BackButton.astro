---
import BackIcon from "../../assets/icons/chevron.svg";

interface Props {
    href: string;
}

const { href } = Astro.props;
---

<a href={href} class="button">
    <BackIcon class="button-icon" aria-hidden="true" />
    <span>ZURÜCK</span>
</a>

<style>
    * {
        box-sizing: border-box;
    }

    .button {
        /* Layout & Flexbox */
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        padding: 0.2rem 1rem;
        gap: 0.5rem;

        /* Typografie */
        text-decoration: none;
        color: var(--title-color);
        font-family: var(--font-heading);
        font-weight: 700;
        font-size: 1rem;

        background: var(--bg-color);
        border: 2px solid var(--outline-color);
        filter: drop-shadow(3px 3px 0 var(--shadow-color));

        /* Micro-Interactions */
        transition:
            transform 0.08s ease,
            filter 0.08s ease,
            background-color 0.15s ease,
            color 0.15s ease;
    }

    .button-icon {
        width: 1rem;
        height: 1rem;
        fill: currentColor;
        stroke: currentColor;
        transition:
            fill 0.15s ease,
            stroke 0.15s ease;
        transform: rotate(-90deg);
    }

    /* Hover-Effekt: Invertiert Farben & verstärkt Schatten */
    .button:hover {
        transform: translate(-1.5px, -1.5px);
        filter: drop-shadow(4.5px 4.5px 0 var(--shadow-color));
        background: var(--text-color);
        color: var(--bg-color);
    }

    .button:hover .button-icon {
        fill: currentColor;
        stroke: currentColor;
    }

    /* Klick-Effekt: Drückt den Button rein */
    .button:active {
        transform: translate(1.5px, 1.5px);
        filter: none;
    }
</style>
