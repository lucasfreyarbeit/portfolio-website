---
import Logo from "../ui/Logo.astro";
import Button from "../ui/Button.astro";
import Accessibility from "../ui/Accessibility.astro";
---

<header class="header">

    <nav class="nav">

        <div class="nav-left">
            <Logo />
        </div>

        <div class="nav-center">
            <Button href="#projekte" variant="red">
                PROJEKTE
            </Button>

            <Button href="#kontakt" variant="blue">
                KONTAKT
            </Button>
        </div>

        <div class="nav-right">
            <Accessibility />
        </div>

    </nav>

    <img
        src="/vector/divider.svg"
        alt=""
        aria-hidden="true"
        class="divider"
    />

</header>

<style>
.header {
    width: 100%;
}

.nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;

    padding: .5rem 1rem;
}

.nav-left {
    justify-self: start;
}

.nav-center {
    display: flex;
    gap: 1rem;
}

.nav-right {
    justify-self: end;
}

.divider {
    display: block;
    width: 100%;
    height: auto;
}
</style>