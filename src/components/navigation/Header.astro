---
import Logo from "../ui/Logo.astro";
import Button from "../ui/Button.astro";
import Accessibility from "../ui/Accessibility.astro";
import DividerDashed from "../ui/DividerDashed.astro";
---

<header class="header">

    <nav class="nav">

        <div class="nav-left">
            <Logo />
        </div>

        <div class="nav-center">
            
        </div>

        <div class="nav-right">
            <Accessibility />
        </div>

    </nav>

   <div class="divider">
    <DividerDashed />
</div>

</header>

<style>
.header {
    width: 100%;
}

.nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;

    padding: .5rem 1rem;
}

.nav-left {
    justify-self: start;
}

.nav-center {
    display: flex;
    gap: 1rem;
}

.nav-right {
    justify-self: end;
}

.divider {
    margin-bottom: 1rem;
}
</style>