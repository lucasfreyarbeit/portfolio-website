---
import BackIcon from '../../assets/icons/chevron.svg';

interface Props {
    backHref: string;
    configHref: string;
}

const { backHref, configHref } = Astro.props;
---

<!-- Der Wrapper klebt jetzt permanent unten und ist nicht mehr unsichtbar -->
<div id="sticky-buttons-container" class="sticky-wrapper">
    <div class="sticky-buttons">

        <!-- Der Back-Button startet unsichtbar und wird via JS gesteuert -->
        <a 
            id="sticky-back-btn" 
            href={backHref} 
            class="button btn-back" 
            data-visible="false"
        >
            <BackIcon class="button-icon" aria-hidden="true" />
            <span>ZURÜCK NACH OBEN</span>
        </a>

        <!-- Der Config-Button ist von Anfang an dauerhaft sichtbar -->
        <a
            href={configHref}
            class="button btn-config"
            aria-label="Darstellungsoptionen öffnen"
        >
            <span>DARSTELLUNG</span>
        </a>

    </div>
</div>

<style>
    .sticky-wrapper {
        position: sticky;
        bottom: 2rem;
        z-index: 99;

        width: 100%;
        margin: 1rem 0;

        pointer-events: none;
    }

    /* Beide Buttons IMMER rechts */
    .sticky-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 1rem;

        width: 100%;
        padding: 0 3rem;
    }

    .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;

        padding: 0.25rem 1.8rem;

        text-decoration: none;
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 700;

        border: 2px solid var(--outline-color);

        filter: drop-shadow(3px 3px 0 var(--shadow-color));

        pointer-events: auto;

        transition:
            transform .08s,
            filter .08s,
            background-color .15s,
            color .15s,
            opacity .25s ease,
            transform .25s ease;
    }

    /* Ein- und Ausblend-Logik exakt auf den Back-Button angewendet */
    .btn-back {
        background: var(--accent-blue-highlight);
        color: var(--bg-color);
        opacity: 0;
        transform: translateY(20px);
        pointer-events: none; /* Deaktiviert Klicks, solange unsichtbar */
    }

    .btn-back[data-visible="true"] {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto; /* Reaktiviert Klicks bei Sichtbarkeit */
    }

    .btn-config {
        background: var(--accent-red-highlight);
        color: var(--bg-color);
    }

    .button-icon {
        width: 1rem;
        height: 1rem;

        fill: currentColor;
        stroke: currentColor;
    }

    .button:hover {
        transform: translate(-1.5px, -1.5px);
        filter: drop-shadow(4.5px 4.5px 0 var(--shadow-color));
    }

    .btn-back:hover {
        background: var(--accent-blue-vibrant);
    }

    .btn-config:hover {
        background: var(--accent-red-vibrant);
    }

    .button:active {
        transform: translate(1.5px, 1.5px);
        filter: none;
    }

    .button:focus-visible {
        outline: 2px solid var(--accent-red-highlight);
        outline-offset: 4px;
    }

    @media (max-width: 768px) {
        .sticky-buttons {
            flex-direction: column;
            align-items: flex-end;
        }
    }
</style>

<script>
    function initStickyButtonsObserver() {
        const hero = document.querySelector('#hero');
        const backBtn = document.querySelector('#sticky-back-btn');

        if (!backBtn) return;

        if (hero) {
            const observer = new IntersectionObserver((entries) => {
                entries.forEach((entry) => {
                    backBtn.setAttribute(
                        'data-visible',
                        (!entry.isIntersecting).toString()
                    );
                });
            }, {
                threshold: 0,
                rootMargin: "-600px 0px 0px 0px" 
            });

            observer.observe(hero);
        } else {
            backBtn.setAttribute('data-visible', 'true');
        }
    }

    initStickyButtonsObserver();
    document.addEventListener('astro:after-swap', initStickyButtonsObserver);
</script>

