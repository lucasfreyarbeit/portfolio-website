---
import Button from "../navigation/Button.astro";
import ImageBox from "../ui/ImageBox.astro";
import Logo from "../ui/Logo.astro";
import FadeIn from "../animations/FadeIn.svelte";
import DownloadIcon from "../../assets/icons/download.svg";
---

<section id="hero">

    <div class="row">

        <!-- Links: Portrait & Meta -->
        <div class="column-left border-left-solid border-right-dashed">
            
            <div class="portrait-wrapper">
                <FadeIn client:load delay={0} immediate>
                    <ImageBox
                        src="/images/portraits/Downscaled.jpg"
                        alt="Portrait von Lucas"
                    />
                </FadeIn>
            </div>

            <FadeIn client:load delay={0} immediate>
                <div class="status-indicator">
                    <span class="dot"></span>
                    <span class="status-text">OFFEN FÜR ANFRAGEN</span>
                </div>
            </FadeIn>

            <div class="meta-section">
                <FadeIn client:load delay={150} immediate>
                    <div class="meta-details">
                     <div class="meta-item">
                            <span class="meta-label">Suche nach:</span>
                            <span class="meta-value">Ausbildung oder Quereinstieg</span>
                        </div>

                        <div class="meta-item">
                            <span class="meta-label">Fokus:</span>
                            <span class="meta-value">Web-Entwicklung, Produktdesign, UI + UX</span>
                        </div>

                        <div class="meta-item">
                            <span class="meta-label">Verfügbar:</span>
                            <span class="meta-value">Ab sofort</span>
                        </div>

                        <div class="meta-item">
                            <span class="meta-label">Standort:</span>
                            <span class="meta-value">Ochsenhausen</span>
                        </div>

                        <div class="meta-item">
                            <span class="meta-label">Arbeitsort:</span>
                            <span class="meta-value">Vor Ort und Remote</span>
                        </div>
                    </div>
                </FadeIn>
            </div>

        </div>

        <!-- Rechts: Inhalt & Navigation -->
        <div class="column-right border-right-solid">

            <!-- Branding / Top Section -->
            <div class="branding-block">
                <FadeIn client:load delay={100} immediate>
                    <div class="logo-wrapper">
                        <Logo variant="black" />
                    </div>
                </FadeIn>

                <FadeIn client:load delay={200} immediate>
                    <h2 class="subheading">
                        <span class="text-designer">DESIGNER.</span>
                        <span class="text-developer">DEVELOPER.</span>
                    </h2>
                </FadeIn>
            </div>

            <!-- Inhaltsbereich (Über mich & Toolstack) -->
            <div class="main-content">
                <FadeIn client:load delay={300} immediate>
                    <section class="content-section">
                        <h3 class="section-title">ÜBER MICH</h3>
                        <p>
                            Ich verbinde Development, Design und Business.
                            Als technischer Generalist löse ich Probleme
                            auf jeder Ebene eines Projekts: Ich entwickle
                            das Produkt, gestalte das gesamte Branding samt
                            Design und kümmere mich um das Publishing sowie
                            das strategische Skalieren.
                        </p>
                    </section>
                </FadeIn>

                <FadeIn client:load delay={400} immediate>
                    <section class="content-section toolstack-section">
                        <h3 class="section-title">TOOLSTACK</h3>
                        <div class="stack-grid">
                            <span class="tech-tag">Astro</span>
                            <span class="tech-tag">HTML / CSS</span>
                            <span class="tech-tag">VS Code</span>
                            <span class="tech-tag">Git / GitHub</span>
                            <span class="tech-tag">Godot Engine</span>
                        </div>
                    </section>
                </FadeIn>
            </div>

            <!-- Action Buttons -->
            <nav class="action-area">
                <FadeIn client:load delay={500} immediate>
                    <Button href="#projekte" variant="red">PROJEKTE</Button>
                </FadeIn>

                <FadeIn client:load delay={600} immediate>
                    <Button href="#kontakt" variant="blue">KONTAKT</Button>
                </FadeIn>

                <FadeIn client:load delay={700} immediate>
                    <Button
                        href="/documents/Lebenslauf-Lucas-Frey.pdf"
                        download
                        variant="red"
                    >
                        <DownloadIcon /> LEBENSLAUF.PDF
                    </Button>
                </FadeIn>
            </nav>

        </div>

    </div>

</section>

<style>
    * {
        box-sizing: border-box;
    }

    #hero {
        width: 100%;
        padding-top: 1rem;
        min-height: 100dvh;
        display: flex;
    }

    .row {
        display: flex;
        align-items: stretch;
        width: 100%;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .column-left,
    .column-right {
        padding: 2rem;
        border-top: 3px solid var(--border-color);
        border-bottom: 0px;
    }

    /* LEFT COLUMN */
    .column-left {
        display: flex;
        flex: 0.5;
        flex-direction: column;
        justify-content: flex-start;
    }

    .portrait-wrapper {
        width: 100%;
    }

    .meta-section {
        margin-top: 1.25rem;
        padding-top: 1.25rem;
        border-top: 2px dashed var(--border-color);
    }

    .meta-details {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .meta-item {
        display: flex;
        flex-direction: row;
        align-items: baseline;
        gap: 0.4rem;
    }

    .meta-label {
        font-family: var(--font-heading);
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-color);
        text-transform: uppercase;
    }

    .meta-value {
        font-size: 1rem;
        font-style: italic;
        line-height: 1.4;
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1.25rem;
        margin-bottom: -1rem;
    }

    .dot {
        width: 15px;
        height: 15px;
        background-color: #00ff66;
        border: 2px solid var(--border-color);
        border-radius: 50%;
        filter: drop-shadow(0.1em 0.1em 0 var(--shadow-color));
    }

    .status-text {
        font-family: var(--font-heading);
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    /* RIGHT COLUMN */
    .column-right {
        display: flex;
        flex: 1;
        flex-direction: column;
    }

    /* Branding Block */
    .branding-block {
        padding-bottom: 1.25rem;
        border-bottom: 2px dashed var(--border-color);
    }

    .logo-wrapper {
        margin: 1.2rem 0 2rem -0.4rem;
        transform: scale(3);
        transform-origin: left center;
    }

    .subheading {
        margin: 0;
        font-family: var(--font-heading);
        font-size: 160%;
        font-weight: 700;
    }

    .text-designer {
        margin-right: 1rem;
        color: var(--accent-2);
    }

    .text-developer {
        color: var(--accent-1);
    }

    /* Inhaltsbereich */
    .main-content {
        padding-top: 1rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .content-section {
        margin-bottom: 2rem;
    }

    .toolstack-section {
        margin-top: auto;
        margin-bottom: 1rem;
    }

    .section-title {
        margin: 0 0 0.75rem;
        font-family: var(--font-heading);
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .content-section p {
        margin: 0;
        font-size: var(--step-body);
        font-style: italic;
        line-height: 1.6;
    }

    .stack-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tech-tag {
        padding: 0.4rem 0.8rem;
        font-family: var(--font-heading);
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--text-color);
        background: transparent;
        border: 2px solid var(--border-color);
    }

    /* Action Buttons Area */
    .action-area {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        width: 100%;
        margin-top: auto;
        padding-top: 1.5rem;
        border-top: 2px dashed var(--border-color);
    }

    /* Rasterlinien */
    .border-left-solid {
        border-left: 3px solid var(--border-color);
    }

    .border-right-solid {
        border-right: 3px solid var(--border-color);
    }

    .border-right-dashed {
        border-right: 2px dashed var(--border-color);
    }

    /* Responsives Layout */
    @media (max-width: 992px) {
        .action-area {
            flex-direction: column;
        }
    }

    @media (max-width: 768px) {
        #hero {
            height: auto;
            padding-top: 2rem;
        }

        .row {
            flex-direction: column;
        }

        .column-left {
            padding-bottom: 1rem;
            border-right: 3px solid var(--border-color);
            border-bottom: none;
        }

        .column-right {
            border-top: 2px dashed var(--border-color);
        }

        .logo-wrapper {
            transform: scale(2);
        }

        .action-area {
            flex-direction: row;
            margin-top: 2rem;
        }
    }

    @media (max-width: 480px) {
        .action-area {
            flex-direction: column;
        }
    }
</style>