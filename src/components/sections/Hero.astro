---
import Button from "../ui/Button.astro";
---

<section id="hero">
    <section id="introduction">
        <div class="row">
            
            <div class="column-left">
                <h1 class="title">DESIGNER. DEVELOPER.</h1>
                <img class="portrait" src="/images/portraits/Downscaled.jpg" alt="Portrait von Lucas">
            </div>

            <div class="column-right">
                <h2>ÜBER MICH</h2>
                <p>bla bla bla bla..<br>
                   ganz viel text<br>
                   und so
                </p>

                <div class="buttons">
                    <Button href="#projekte" variant="red">
                        PROJEKTE
                    </Button>

                    <Button href="#kontakt" variant="blue">
                        KONTAKT
                    </Button>

                    <Button href="/documents/Lebenslauf-Lucas-Frey.pdf" download variant="red">
                        LEBENSLAUF.PDF
                    </Button>
                </div>
            </div>

        </div>
    </section>
</section>

<style>
* {
    box-sizing: border-box;
}

.row {
    display: flex;
    flex-direction: row;
    gap: 0rem;
    
    /* Zwingt die Box, sich über die gesamte verfügbare Breite auszudehnen */
    width: 100%; 
    margin: 0 auto; 
    
    /* Ein bisschen Seitenabstand, damit die Box auf Laptops/Tablets nicht am Bildschirmrand klebt */
    padding: 2rem 2rem; 
}

.column-left {
    border: 3px solid var(--border-color);
    border-right-style: dashed;
    border-right-width: 2px;
    flex: 0.5; /* Nimmt sich dauerhaft 1/3 des Platzes */
    padding: 1.5rem;
}

.column-right {
    border: 3px solid var(--border-color);
    border-left-width: 0px;
    flex: 1; /* Nimmt sich dauerhaft 2/3 des Platzes */
    padding: 1.5rem;
    
    display: flex;
    flex-direction: column;
}

.title {
    margin-bottom: 1rem;
    font-weight: 700;
    font-size: 160%;
}

.portrait {
    border: 3px solid var(--border-color);
    filter: drop-shadow(0.2em 0.2em 0 var(--shadow-color));
    max-width: 100%;
    height: auto;
    transition: transform 0.08s ease, filter 0.08s ease;
}

.portrait:hover {
    transform: translate(-0.1em, -0.1em);
    filter: drop-shadow(0.3em 0.3em 0 var(--shadow-color));
}

.buttons {
    margin-top: auto; 
    display: flex;
    justify-content: center; 
    gap: 1.5rem; 
    padding-top: 2rem; 
    width: 100%;
}
</style>