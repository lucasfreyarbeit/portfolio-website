---
// Import-Anweisungen
import Button from "../navigation/Button.astro";
import ImageBox from "../ui/ImageBox.astro";
import Logo from "../ui/Logo.astro";
import FadeIn from "../animations/FadeIn.svelte";
import DownloadIcon from "../../assets/icons/download.svg";

// Typdefinitionen
interface ToolItem {
    name: string;
    breakAfter?: boolean;
}

interface ToolCategory {
    category: string;
    items: ToolItem[];
}

// Datenstruktur für den Toolstack
const toolCategories: ToolCategory[] = [
    {
        category: "ENTWICKLUNG",
        items: [
            { name: "VS Code" },
            { name: "Git & GitHub" },
            { name: "Godot Engine" },
            { name: "Roblox Studio" },
            { name: "Android Studio" }
        ]
    },
    {
        category: "DESIGN & 3D",
        items: [
            { name: "Affinity Studio" },
            { name: "Penpot" },
            { name: "Blender" },
            { name: "Blockbench" },
            { name: "MagicaVoxel" },
            { name: "Material Maker" }
        ]
    },
    {
        category: "WORKFLOW & ORGA",
        items: [
            { name: "Notion" },
            { name: "Obsidian" },
            { name: "Google Workspace", breakAfter: true },
            { name: "Fedora Linux" }
        ]
    }
];
---

<section id="hero">
    <div class="row">

        <!-- Linke Spalte: Portrait- und Metadaten-Sektion -->
        <div class="column-left border-left-solid border-right-dashed">
            
            <div class="portrait-wrapper">
                <FadeIn client:load delay={0} immediate>
                    <ImageBox
                        src="/images/portraits/Downscaled.jpg"
                        alt="Portrait von Lucas"
                    />
                </FadeIn>
            </div>

            <FadeIn client:load delay={0} immediate>
                <div class="status-indicator">
                    <span class="dot" aria-hidden="true"></span>
                    <span class="status-text">OFFEN FÜR ANFRAGEN</span>
                </div>
            </FadeIn>

            <div class="meta-section">
                <FadeIn client:load delay={150} immediate>
                    <div class="meta-details">
                        <div class="meta-item">
                            <span class="meta-label">Suche nach:</span>
                            <span class="meta-value">Ausbildung oder Quereinstieg</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Fokus:</span>
                            <span class="meta-value">Web-Entwicklung, Produktdesign, UI + UX</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Verfügbar:</span>
                            <span class="meta-value">Ab sofort</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Standort:</span>
                            <span class="meta-value">Ochsenhausen</span>
                        </div>
                        <div class="meta-item">
                            <span class="meta-label">Arbeitsort:</span>
                            <span class="meta-value">Vor Ort und Remote</span>
                        </div>
                    </div>
                </FadeIn>
            </div>
        </div>

        <!-- Rechte Spalte: Inhalts- und Navigationsbereich -->
        <div class="column-right border-right-solid">

            <!-- Branding-Bereich -->
            <div class="branding-block">
                <FadeIn client:load delay={100} immediate>
                    <div class="logo-wrapper">
                        <Logo variant="black" />
                    </div>
                </FadeIn>

                <FadeIn client:load delay={200} immediate>
                    <h2 class="subheading">
                        <span class="text-designer">DESIGNER.</span>
                        <span class="text-developer">DEVELOPER.</span>
                    </h2>
                </FadeIn>
            </div>

            <!-- Hauptinhalt -->
            <div class="main-content">
                <FadeIn client:load delay={300} immediate>
                    <section class="content-section">
                        <h3 class="section-title">ÜBER MICH</h3>
                        <p>
                            Ich verbinde Development, Design und Business.
                            Als technischer Generalist löse ich Probleme
                            auf jeder Ebene eines Projekts: Ich entwickle
                            das Produkt, gestalte das gesamte Branding samt
                            Design und kümmere mich um das Publishing sowie
                            das strategische Skalieren.
                        </p>
                    </section>
                </FadeIn>

                <!-- Toolstack-Sektion -->
                <section class="content-section toolstack-section">
                    <FadeIn client:load delay={400} immediate>
                        <h3 class="section-title">TOOLSTACK & SOFTWARE</h3>
                        
                        <div class="tools-grid">
                            {toolCategories.map((group: ToolCategory) => (
                                <div class="tool-group">
                                    <h4 class="group-title">{group.category}</h4>
                                    <div class="stack-grid">
                                        {group.items.map((item: ToolItem) => (
                                            <span class={`tech-tag ${item.breakAfter ? "break-after" : ""}`}>
                                                {item.name}
                                            </span>
                                        ))}
                                    </div>
                                </div>
                            ))}
                        </div>
                    </FadeIn>
                </section>

                <!-- Hinweis zur Software-Auswahl -->
                <div class="toolstack-note-container">
                    <FadeIn client:load delay={450} immediate>
                        <p class="toolstack-note">
                            *Auszug der primär genutzten Software. Detaillierte Stacks & Frameworks sind in den jeweiligen Projekten aufgeführt.
                        </p>
                    </FadeIn>
                </div>

                <!-- Aktions-Schaltflächen -->
                <nav class="action-area" aria-label="Aktionsmenü">
                    <FadeIn client:load delay={500} immediate>
                        <Button href="#projekte" variant="red">PROJEKTE</Button>
                    </FadeIn>

                    <FadeIn client:load delay={600} immediate>
                        <Button href="#kontakt" variant="blue">KONTAKT</Button>
                    </FadeIn>

                    <FadeIn client:load delay={700} immediate>
                        <Button
                            href="/documents/Lebenslauf-Lucas-Frey.pdf"
                            download
                            variant="red"
                        >
                            <DownloadIcon aria-hidden="true" /> LEBENSLAUF.PDF
                        </Button>
                    </FadeIn>
                </nav>
            </div>
        </div>
    </div>
</section>

<style>
    /* Globale Reset- und Layout-Styles */
    * {
        box-sizing: border-box;
    }

    #hero {
        width: 100%;
        padding-top: 1rem;
        min-height: 100dvh;
        display: flex;
    }

    .row {
        display: flex;
        align-items: stretch;
        width: 100%;
        margin: 0 auto;
        padding: 0 1rem;
    }

    .column-left,
    .column-right {
        padding: 2rem;
        border-top: 3px solid var(--border-color);
        border-bottom: 0px;
    }

    /* Linke Spalte */
    .column-left {
        display: flex;
        flex: 0.5;
        flex-direction: column;
        justify-content: flex-start;
    }

    .portrait-wrapper {
        width: 100%;
    }

    .meta-section {
        margin-top: 1.25rem;
        padding-top: 1.25rem;
        border-top: 2px dashed var(--border-color);
    }

    .meta-details {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .meta-item {
        display: flex;
        flex-direction: row;
        align-items: baseline;
        gap: 0.4rem;
    }

    .meta-label {
        font-family: var(--font-heading);
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--text-color);
        text-transform: uppercase;
    }

    .meta-value {
        font-size: 1rem;
        font-style: italic;
        line-height: 1.4;
    }

    .status-indicator {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1.25rem;
        margin-bottom: -1rem;
    }

    .dot {
        width: 15px;
        height: 15px;
        background-color: #00ff66;
        border: 2px solid var(--border-color);
        border-radius: 50%;
        filter: drop-shadow(0.1em 0.1em 0 var(--shadow-color));
    }

    .status-text {
        font-family: var(--font-heading);
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: 0.05em;
    }

    /* Rechte Spalte */
    .column-right {
        display: flex;
        flex: 1;
        flex-direction: column;
    }

    /* Branding-Block */
    .branding-block {
        padding-bottom: 1.25rem;
        border-bottom: 2px dashed var(--border-color);
    }

    .logo-wrapper {
        margin: 1.2rem 0 2rem -0.4rem;
        transform: scale(3);
        transform-origin: left center;
    }

    .subheading {
        margin: 0;
        font-family: var(--font-heading);
        font-size: 160%;
        font-weight: 700;
    }

    .text-designer {
        margin-right: 1rem;
        color: var(--accent-blue-highlight);
    }

    .text-developer {
        color: var(--accent-red-highlight);
    }

    /* Inhaltsbereich */
    .main-content {
        padding-top: 1rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
    }

    .content-section {
        margin-bottom: 2.25rem;
    }

    .toolstack-section {
        margin-top: auto;
        margin-bottom: 0;
    }

    .section-title {
        margin: 0 0 0.9rem;
        font-family: var(--font-heading);
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.05em;
        text-transform: uppercase;
    }

    .content-section p {
        margin: 0;
        font-size: var(--step-body);
        font-style: italic;
        line-height: 1.6;
    }

    /* Toolstack Raster */
    .tools-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
    }

    .tool-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .group-title {
        margin: 0;
        font-family: var(--font-heading);
        font-size: var(--step-small);
        font-weight: 700;
        color: var(--text-color);
        text-transform: uppercase;
        opacity: 0.8;
    }

    .stack-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .tech-tag {
        padding: 0.35rem 0.65rem;
        font-family: var(--font-heading);
        font-size: 0.8rem;
        font-weight: 600;
        text-transform: uppercase;
        color: var(--text-color);
        background: transparent;
        /* KORREKTUR: Standardwert für durchgehenden Rahmen gesetzt */
        border: 2px solid var(--border-color);
        white-space: nowrap;
        width: fit-content;
    }

    .tech-tag.break-after {
        margin-right: 100%;
    }

    .toolstack-note-container {
        margin-top: auto;
    }

    .toolstack-note {
        margin-top: 8rem;
        margin-bottom: 0rem;
        font-size: var(--step-small);
        font-style: italic;
        line-height: 1.4;
        opacity: 0.75;
    }

    /* Aktions-Schaltflächen */
    .action-area {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        width: 100%;
        margin-top: auto;
        padding-top: 1.5rem;
        border-top: 2px dashed var(--border-color);
    }

    /* Hilfsklassen für Rasterlinien */
    .border-left-solid { border-left: 3px solid var(--border-color); }
    .border-right-solid { border-right: 3px solid var(--border-color); }
    .border-right-dashed { border-right: 2px dashed var(--border-color); }

    /* Responsives Layout */
    @media (max-width: 992px) {
        .action-area {
            flex-direction: column;
        }
    }

    @media (max-width: 768px) {
        #hero {
            height: auto;
            padding-top: 2rem;
        }

        .row {
            flex-direction: column;
        }

        .column-left {
            padding-bottom: 1rem;
            border-right: 3px solid var(--border-color);
            border-bottom: none;
        }

        .column-right {
            border-top: 2px dashed var(--border-color);
        }

        .logo-wrapper {
            transform: scale(2);
        }

        .action-area {
            flex-direction: row;
            margin-top: 2rem;
        }
    }

    @media (max-width: 480px) {
        .action-area {
            flex-direction: column;
        }
    }
</style>