---
import Button from "../navigation/Button.astro";
import ImageBox from "../ui/ImageBox.astro";
import FadeIn from "../animations/FadeIn.svelte";
---

<section id="projekte">

    <!-- Projektkarte 01 -->
    <div class="row">

        <div class="col-image border-top-solid border-left-solid border-right-dashed">
            <FadeIn client:visible delay={0}>
                <ImageBox
                    src="/images/projects/Placeholder.png"
                    alt="Projekt 1 Vorschau"
                />
            </FadeIn>
        </div>

        <div class="col-text border-top-solid border-right-solid">

            <FadeIn client:visible delay={100}>
                <h1 class="title">PROJEKT 1</h1>
            </FadeIn>

            <FadeIn client:visible delay={200}>
                <h2>BESCHREIBUNG</h2>
            </FadeIn>

            <FadeIn client:visible delay={300}>
                <p>
                    bla bla bla bla...<br />
                    ganz viel Text<br />
                    und so
                </p>
            </FadeIn>

            <FadeIn client:visible delay={350}>
                <div class="tech-stack">
                    <h2>VERWENDETE TECHNOLOGIEN</h2>
                    <div class="tags">
                        <span class="tag">ASTRO</span>
                        <span class="tag">SVELTE</span>
                        <span class="tag">CSS</span>
                    </div>
                </div>
            </FadeIn>

            <div class="button-wrapper">
                <div class="buttons">
                    <!-- Sequenzielles Einblenden der Aktions-Buttons -->
                    <FadeIn client:visible delay={400}>
                        <Button
                            href="/projekte/projekt-1"
                            variant="red"
                        >
                            PROJEKT GENAUER ANSEHEN
                        </Button>
                    </FadeIn>

                    <FadeIn client:visible delay={500}>
                        <Button
                            href="#"
                            variant="blue"
                        >
                            LIVE DEMO
                        </Button>
                    </FadeIn>
                </div>
            </div>

        </div>

    </div>

    <!-- Projektkarte 02 -->
    <div class="row">

        <div class="col-text border-left-solid border-right-dashed">

            <FadeIn client:visible delay={0}>
                <h1 class="title">PROJEKT 2</h1>
            </FadeIn>

            <FadeIn client:visible delay={100}>
                <h2>BESCHREIBUNG</h2>
            </FadeIn>

            <FadeIn client:visible delay={200}>
                <p>
                    was soll ich hier nur reinschreiben ugh<br />
                    noch mehr geblubber<br />
                    naja egal
                </p>
            </FadeIn>

            <FadeIn client:visible delay={250}>
                <div class="tech-stack">
                    <h2>VERWENDETE TECHNOLOGIEN</h2>
                    <div class="tags">
                        <span class="tag">GODOT</span>
                        <span class="tag">GDSCRIPT</span>
                        <span class="tag">BLENDER</span>
                    </div>
                </div>
            </FadeIn>

            <div class="button-wrapper">
                <div class="buttons">
                    <!-- Sequenzielles Einblenden der Aktions-Buttons -->
                    <FadeIn client:visible delay={300}>
                        <Button
                            href="/projekte/projekt-2"
                            variant="red"
                        >
                            PROJEKT GENAUER ANSEHEN
                        </Button>
                    </FadeIn>

                    <FadeIn client:visible delay={400}>
                        <Button
                            href="#"
                            variant="blue"
                        >
                            LIVE DEMO
                        </Button>
                    </FadeIn>
                </div>
            </div>

        </div>

        <div class="col-image border-right-solid">
            <FadeIn client:visible delay={400}>
                <ImageBox
                    src="/images/projects/Placeholder.png"
                    alt="Projekt 2 Vorschau"
                />
            </FadeIn>
        </div>

    </div>

</section>

<style>
    * {
        box-sizing: border-box;
    }

    /* Haupt-Grid-Struktur */
    .row {
        display: flex;
        align-items: stretch;

        width: 100%;
        margin: 0 auto;
        padding: 0 1rem;
    }

    /* Spalten-Layouts & Gemeinsame Rahmen */
    .col-image,
    .col-text {
        padding: 1.5rem;
        border-bottom: 3px solid var(--border-color);
    }

    .col-image {
        flex: 0.5;
    }

    .col-text {
        display: flex;
        flex: 1;
        flex-direction: column;
    }

    .col-text p {
        font-style: italic;
    }

    /* Varianten für Grid-Linien */
    .border-top-solid {
        border-top: 3px solid var(--border-color);  
    }   
        
    .border-left-solid {
        border-left: 3px solid var(--border-color);
    }

    .border-right-solid {
        border-right: 3px solid var(--border-color);
    }

    .border-right-dashed {
        border-right: 2px dashed var(--border-color);
    }

    /* Typografie */
    .title {
        margin: 0;

        font-size: 400%;
        font-weight: 700;
    }

    /* Tech-Stack Badges */
    .tech-stack {
        margin-top: 1.5rem;
        margin-bottom: 1.5rem;
    }

    .tech-stack h2 {
        margin-bottom: 0.5rem;
        font-size: 100%;
    }

    .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

    .tag {
        padding: 0.4rem 0.8rem;

        border: 2px solid var(--border-color);
        background-color: transparent;

        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    /* Button-Container & Fixierung am unteren Rand */
    .button-wrapper {
        width: 100%;
        margin-top: auto;
    }

    .buttons {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: flex-start;

        width: 100%;
        padding-top: 1.5rem;
        border-top: 2px dashed var(--border-color);
    }
</style>