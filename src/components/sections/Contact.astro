---
import Button from "../navigation/Button.astro";
import FadeIn from "../animations/FadeIn.svelte";
---

<section id="kontakt">
    <div class="row">
        <div class="col-full border-left-solid border-right-solid">

            <!-- Einleitung -->
            <FadeIn client:load>
                <h1 class="title1">KONTAKT</h1>
                <h2>ICH FREUE MICH AUF DICH!</h2>

                <p class="description">
                    Du hast eine offene Stelle, einen Ausbildungsplatz oder möchtest
                    mich für ein Vorstellungsgespräch einladen? Schreib mir direkt –
                    ich melde mich umgehend.
                </p>
            </FadeIn>

            <!-- Formular -->
            <form class="contact-form">

                <FadeIn client:load delay={100}>
                    <div class="form-group">
                        <label for="name">UNTERNEHMEN / NAME</label>
                        <input
                            type="text"
                            id="name"
                            name="name"
                            required
                            placeholder="Name des Studios oder der Agentur"
                        />
                    </div>
                </FadeIn>

                <FadeIn client:load delay={200}>
                    <div class="form-group">
                        <label for="email">EMAIL</label>
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            placeholder="deine.email@firma.de"
                        />
                    </div>
                </FadeIn>

                <FadeIn client:load delay={300}>
                    <div class="form-group">
                        <label for="message">NACHRICHT</label>
                        <textarea
                            id="message"
                            name="message"
                            rows="5"
                            required
                            placeholder="Hi Lucas, wir würden dich gerne zu einem Gespräch einladen..."
                        ></textarea>
                    </div>
                </FadeIn>

                <FadeIn client:load delay={400}>
                    <div class="buttons">
                        <Button href="#" variant="blue">
                            ANFRAGE SENDEN
                        </Button>
                    </div>
                </FadeIn>

            </form>

        </div>
    </div>
</section>

<style>
    * {
        box-sizing: border-box;
    }

    .row {
        display: flex;
        flex-direction: row;
        width: 100%;
        margin: 0 auto;
        padding: 0 1rem;
    }

    /* Formularbereich im Seitenraster */
    .col-full {
        flex: 1;
        display: flex;
        flex-direction: column;
        padding: 0 1.5rem 1.5rem;

        border-top: 0;
        border-bottom: 3px solid var(--border-color);
    }

    /* Außenkanten des Rasters */
    .border-left-solid {
        border-left: 3px solid var(--border-color);
    }

    .border-right-solid {
        border-right: 3px solid var(--border-color);
    }

    .title1 {
        margin-bottom: 0.5rem;
        font-size: 400%;
        font-weight: 700;
    }

    .description {
        font-style: italic;
    }

    /* Formularlayout */
    .contact-form {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;

        width: 100%;
        max-width: 600px;

        margin-top: 1.5rem;
    }

    /* Eingabebereich */
    .form-group {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;

        padding: 1rem;

        background: var(--bg-color);
        border: 3px solid var(--outline-color);

        transition:
            border-color 0.2s ease,
            box-shadow 0.2s ease;
    }

    /* Fokuszustand */
    .form-group:focus-within {
        border-color: var(--accent-color2, #0055ff);
        box-shadow: 4px 4px 0 var(--accent-color2, #0055ff);
    }

    .form-group label {
        font-family: var(--font-heading);
        font-size: 1.1rem;
        font-weight: 700;
        letter-spacing: 0.05em;

        transition: color 0.2s ease;
    }

    .form-group:focus-within label {
        color: var(--accent-color2, #0055ff);
    }

    /* Texteingaben */
    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 0.5rem 0;

        font: inherit;
        color: var(--text-color);

        background: transparent;
        border: none;
        border-bottom: 2px solid rgba(0, 0, 0, 0.1);
    }

    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-bottom-color: var(--accent-color2, #0055ff);
    }

    /* Button-Ausrichtung */
    .buttons {
        display: flex;
        justify-content: flex-start;

        width: 100%;
        margin-top: 0rem;
    }
</style>