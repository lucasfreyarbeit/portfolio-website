        font-family: var(--font-heading, "Roboto Mono", monospace);
        font-weight: 700;
        font-size: clamp(2rem, 7vw, 5rem);
        line-height: 0.95;
        letter-spacing: -0.02em;

        margin: 0;
    }

    /* Text-Gruppe zur exakten Steuerung des Zeilenabstands */
