<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lucas Frey Portfolio</title>

    <link rel="stylesheet" href="/css/kalam.css">
    <link rel="stylesheet" href="/css/varela-round.css">
</head>

<body>
    <main class="hero">
        <h1 class="hero-title">Lucas Frey</h1>
        <p class="hero-subtitle">Diese Website befindet sich momentan in der Entwicklung.</p>
    </main>

    <!-- Divider / divider -->
    <div class="footer-divider" aria-hidden="true"></div>

    <!-- Footer / footer -->
    <footer class="footer">
        <div class="footer-inner">
            
            <!-- Copyright / copyright -->
            <p class="footer-copy">© 2026 Lucas Frey</p>

            <!-- Source Pille / source pill -->
            <a
                 href="https://github.com/lucasfreyarbeit/portfolio-website"
                class="footer-source"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Quellcode der Webseite auf GitHub öffnen"
                >
                <img class="footer-source-icon" src="/images/github.svg" alt="">
                <span class="footer-source-text">Quellcode der Webseite auf GitHub öffnen</span>
            </a>

            <!-- Rechtliches / legal -->
            <nav class="footer-links" aria-label="Rechtliches">
                <a href="/impressum" class="footer-link">Impressum</a>
                <a href="/datenschutz" class="footer-link">Datenschutz</a>
            </nav>

           
        </div>
    </footer>
</body>
</html>

<style>
    :root {
        --page-bg: #0f0f0f;
        --surface: #212121;
        --surface-raised: #303030;
        --border: #2a2a2a;

        --text-primary: #f3f4f6;
        --text-muted: #8e8e93;
        --text-dim: #5b5b5b;

        --content-width: 850px;
        --transition-fast: 0.2s ease;
    }

    * {
        box-sizing: border-box;
    }

    html,
    body {
        margin: 0;
        min-height: 100%;
        background-color: var(--page-bg);
        color: var(--text-primary);
        font-family: 'Varela-Round', system-ui, sans-serif;
    }

    body {
        min-height: 100svh;
        display: flex;
        flex-direction: column;
    }

    /* Hero / hero */
    .hero {
        width: min(100% - 40px, var(--content-width));
        min-height: 72svh;
        margin-inline: auto;

        display: flex;
        flex-direction: column;
        flex: 1;
        align-items: center;
        justify-content: center;

        text-align: center;
    }


    .hero-title {
        margin: 0;
        font-family: 'Kalam-Bold', sans-serif;
        font-size: clamp(4rem, 8vw, 5.5rem);
        line-height: 1;
    }

    .hero-subtitle {
        max-width: 600px;
        margin: 20px 0 0;
        color: var(--text-muted);
        font-size: 1.25rem;
    }

    /* Divider / divider */
    .footer-divider {
        width: 100%;
        height: 30px;
        flex-shrink: 0;

        background-image: url("/images/footer-divider.svg");
        background-repeat: no-repeat;
        background-size: 100% 100%;
        background-position: center bottom;
    }

    /* Footer / footer */
    .footer {
    min-height: 140px;
    flex-shrink: 0;
    width: 100%;
    background-color: var(--surface);
    }

    .footer-inner {
    width: calc(100% - 100px);
    min-height: inherit;
    margin-inline: auto;

    display: grid;
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: 24px;
    }


     /* Copyright / copyright */
    .footer-copy {
        justify-self: start;
        margin: 0;

        color: var(--text-dim);
        font-size: 0.95rem;
        white-space: nowrap;
    }

    .footer-link {
        color: var(--text-muted);
        text-decoration: none;
        font-size: 0.95rem;
        transition: color var(--transition-fast);
    }

    .footer-link:hover {
        color: var(--text-primary);
    }

    /* Source Pille / source pill */
    .footer-source {
        justify-self: center;

        min-height: 56px;
        padding: 0 24px;

        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;

        background-color: var(--surface-raised);
        border: 1px solid var(--border);
        border-radius: 999px;

        color: var(--text-muted);
        text-decoration: none;

        transition:
            background-color var(--transition-fast),
            border-color var(--transition-fast);
    }

    .footer-source-icon {
        width: 30px;
        height: 30px;
        filter: brightness(60%);
        transition: filter var(--transition-fast);
    }

    .footer-source-text {
        color: inherit;
        font-size: 1rem;
        transition: color var(--transition-fast);
    }

    .footer-source:hover {
        background-color: #363636;
        border-color: #3d3d3d;
    }

    .footer-source:hover .footer-source-icon {
        filter: brightness(100%);
    }

    .footer-source:hover .footer-source-text {
        color: var(--text-primary);
    }

    /* Rechtliches / legal */
    .footer-links {
        justify-self: end;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

   
    /* Fokus / focus */
    .footer-link:focus-visible,
    .footer-source:focus-visible {
        outline: 2px solid var(--text-primary);
        outline-offset: 4px;
    }

    /* Mobil / mobile */
    @media (max-width: 760px) {
        .footer-divider {
            height: 25px;
        }

        .footer-inner {
            width: calc(100% - 32px);
            min-height: 180px;
            padding-block: 28px;

            grid-template-columns: 1fr;
            justify-items: center;
            text-align: center;
        }

        .footer-links,
        .footer-source,
        .footer-copy {
            justify-self: center;
        }

        .footer-links {
            align-items: center;
        }
    }
</style>
