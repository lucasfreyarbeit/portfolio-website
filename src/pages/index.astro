<style is:global>
  /* Versteckt den Scrollbalken für die gesamte Seite */
  html, body {
    /* Für Chrome, Safari und Opera */
    ::-webkit-scrollbar {
      display: none;
    }
    
    /* Für IE, Edge und Firefox */
    -ms-overflow-style: none;  /* IE/Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
